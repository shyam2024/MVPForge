# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database - MongoDB Atlas
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/mvpforge?retryWrites=true&w=majority
MONGODB_DB_NAME=mvpforge

# OpenAI / LLM Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# Application Settings
MAX_PROJECT_SIZE=100
SESSION_TIMEOUT=3600
READINESS_SCORE_THRESHOLD=0.85
